{
  "name": "depssmuggler",
  "version": "1.0.0",
  "type": "module",
  "description": "폐쇄망 환경을 위한 패키지 의존성 다운로드 및 전달 애플리케이션",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json && node -e \"require('fs').writeFileSync('dist/package.json', '{\\\"type\\\":\\\"commonjs\\\"}')\" && electron .",
    "build": "npm run build:vite && npm run build:electron",
    "build:vite": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node -e \"require('fs').writeFileSync('dist/package.json', '{\\\"type\\\":\\\"commonjs\\\"}')\"",
    "watch": "tsc -w",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "package:linux": "npm run build && electron-builder --linux",
    "cli": "ts-node src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "typecheck": "tsc --noEmit",
    "guardrails:bridge": "node scripts/check-renderer-bridge-guardrails.mjs",
    "guardrails:bridge:update-baseline": "node scripts/check-renderer-bridge-guardrails.mjs --update",
    "guardrails:eslint": "node scripts/check-eslint-guardrails.mjs",
    "guardrails:eslint:update-baseline": "node scripts/check-eslint-guardrails.mjs --update",
    "guardrails:typecheck": "node scripts/check-strict-typecheck-baseline.mjs",
    "guardrails:typecheck:update-baseline": "node scripts/check-strict-typecheck-baseline.mjs --update",
    "guardrails:check": "npm run guardrails:bridge && npm run guardrails:eslint && npm run guardrails:typecheck",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\" \"electron/**/*.{ts,js}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\" \"electron/**/*.{ts,js}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --cache --fix",
      "tsc-files --noEmit --pretty false",
      "vitest related --run --passWithNoTests"
    ],
    "*.{js,jsx}": [
      "eslint --cache --fix",
      "vitest related --run --passWithNoTests"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --check"
    ]
  },
  "bin": {
    "depssmuggler": "./dist/src/cli/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonggeun2001/DepsSmuggler.git"
  },
  "keywords": [
    "offline",
    "airgap",
    "dependency",
    "download",
    "pip",
    "maven",
    "docker",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jonggeun2001/DepsSmuggler/issues"
  },
  "homepage": "https://github.com/jonggeun2001/DepsSmuggler#readme",
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/cli-progress": "^3.11.6",
    "@types/fs-extra": "^11.0.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.0.2",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@types/ssri": "^7.1.5",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.0.15",
    "concurrently": "^9.2.1",
    "electron": "^39.8.7",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "playwright": "^1.57.0",
    "prettier": "^3.5.0",
    "sharp": "^0.34.5",
    "tsc-files": "^1.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.0.15"
  },
  "build": {
    "appId": "com.depssmuggler.app",
    "productName": "DepsSmuggler",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "type": "commonjs"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools",
      "icon": "assets/icons/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icons/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icons"
    },
    "publish": {
      "provider": "github",
      "owner": "jonggeun2001",
      "repo": "DepsSmuggler",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@types/archiver": "^7.0.0",
    "antd": "^6.0.1",
    "archiver": "^7.0.1",
    "axios": "^1.15.0",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "eventemitter3": "^5.0.1",
    "fast-xml-parser": "^5.5.12",
    "fs-extra": "^11.3.2",
    "fzstd": "^0.1.1",
    "html-to-image": "^1.11.13",
    "js-yaml": "^4.1.1",
    "node-machine-id": "^1.1.12",
    "nodemailer": "^8.0.5",
    "ora": "^9.0.0",
    "p-limit": "^7.2.0",
    "p-queue": "^9.0.1",
    "react": "^19.2.0",
    "react-d3-tree": "^3.6.6",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.14.1",
    "semver": "^7.7.3",
    "ssri": "^13.0.0",
    "tar": "^7.5.13",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "zustand": "^5.0.9"
  },
  "overrides": {
    "@eslint/eslintrc": {
      "minimatch": "^3.1.5"
    },
    "@humanwhocodes/config-array": {
      "minimatch": "^3.1.5"
    },
    "anymatch": {
      "picomatch": "^2.3.2"
    },
    "archiver-utils": {
      "lodash": "^4.18.1"
    },
    "axios": {
      "follow-redirects": "^1.16.0"
    },
    "eslint": {
      "minimatch": "^3.1.5"
    },
    "eslint-plugin-import": {
      "minimatch": "^3.1.5"
    },
    "eslint-plugin-react": {
      "minimatch": "^3.1.5"
    },
    "fdir": {
      "picomatch": "^4.0.4"
    },
    "flat-cache": {
      "flatted": "^3.4.2"
    },
    "glob@10": {
      "minimatch": "^9.0.9"
    },
    "glob@7": {
      "minimatch": "^3.1.5"
    },
    "readdir-glob": {
      "minimatch": "^5.1.9"
    },
    "readdirp": {
      "picomatch": "^2.3.2"
    },
    "tinyglobby": {
      "picomatch": "^4.0.4"
    },
    "vite": {
      "picomatch": "^4.0.4",
      "rollup": "^4.60.1"
    },
    "vitest": {
      "picomatch": "^4.0.4"
    }
  }
}
